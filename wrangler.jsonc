{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "saragarhi-api-database-test",
	"main": "src/index.js",
	"compatibility_date": "2026-03-10",
	"observability": {
		"enabled": true
	},
	"d1_databases": [{
		"binding": "DB",
		"database_name": "saragarhi_test",
		"database_id": "ce551c17-08e9-48c4-8def-24df7fb370b6",
		"remote": true
	}],
	"kv_namespaces": [
    {
      "binding": "KV",
      "id": "4fb7b75125d848a8b722bdc751403fd2"
    }
  ]
}
